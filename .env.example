OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Optional: Zendesk online credentials (used when mode=online and no config passed in request)
ZENDESK_SUBDOMAIN=yourcompany
ZENDESK_EMAIL=admin@yourcompany.com
ZENDESK_API_TOKEN=

# Optional: Jira online credentials (used when mode=online and no config passed in request)
JIRA_SERVER_URL=https://yourcompany.atlassian.net
JIRA_USERNAME=admin@yourcompany.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
